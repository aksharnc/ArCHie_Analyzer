# ============================================================
#  ArCHie Analyzer — API Keys
#  1. Run:  copy .env.example .env
#  2. Fill in your keys below
#  Tool works without keys — missing ones show ⚠️ NO KEY, never crashes
# ============================================================

# VirusTotal — https://www.virustotal.com/gui/join-us
# Free: 4 req/min | 500/day
VT_API_KEY=

# AbuseIPDB — https://www.abuseipdb.com/register
# Free: 1,000 checks/day
ABUSEIPDB_KEY=

# OTX AlienVault — https://otx.alienvault.com/api
# Free: generous rate limits, covers hash/IP/domain/URL
OTX_KEY=

# GreyNoise — https://viz.greynoise.io/account/signup
# Free Community: 50 checks/day (Personal Access Token)
GREYNOISE_KEY=

# URLScan.io — https://urlscan.io/user/signup
# Free: generous quota
URLSCAN_KEY=

# MalwareBazaar — https://bazaar.abuse.ch/
# Sign in → Account → API Key (free, requires account)
MALWAREBAZAAR_KEY=

# Hybrid Analysis — https://www.hybrid-analysis.com/signup
# Free sandbox reports for hashes (MD5 / SHA1 / SHA256)
HYBRID_ANALYSIS_KEY=

# PhishTank — https://www.phishtank.com/developer_info.php
# Free verified phishing URL database (CISO email triage)
PHISHTANK_KEY=

# NVD (National Vulnerability Database) — https://nvd.nist.gov/developers/request-an-api-key
# Optional — without key: 5 req/30s, with key: 50 req/30s
NVD_API_KEY=

# IPInfo — leave blank for basic geo (no key needed)
# Optional key: https://ipinfo.io/signup for 50k/month
IPINFO_KEY=

# ---- Proxy (do not change) ----
PROXY_HOST=127.0.0.1
PROXY_PORT=8888
